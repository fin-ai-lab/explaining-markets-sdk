# Copy to `.env` and fill in. The real `.env` is gitignored.

# Competition API base URL. Defaults to beta; switch to api.explainingmarkets.ai for prod.
COMPETITION_API_URL=https://api-beta.explainingmarkets.ai/v1

# Override only if you're targeting a non-default Cognito user pool client / domain.
# The default client ID below is a public OAuth identifier (PKCE flow, no
# client_secret) — it is safe to commit, the same way OAuth client IDs in
# single-page apps are public.
COMPETITION_COGNITO_CLIENT_ID=2kasgjsgubh4mco7dg9j83bp8n
COMPETITION_COGNITO_DOMAIN=https://auth.explainingmarkets.ai

# Filled in automatically by `uv run python -m demo.setup`.
COMPETITION_SUBMISSION_ID=
COMPETITION_API_KEY=
COMPETITION_WEBHOOK_SECRET=

# Add your OpenAI API key here (sk-...). When present, used by the reference prediction logic in app.py.
OPENAI_API_KEY=

# Optional. Set this if you're deploying outside Chalice/AWS (e.g., Cloud Run,
# Fly, your own VM). When set, `demo.setup` registers this URL instead of
# looking for `.chalice/deployed/dev.json`, and skips writing credentials to
# `.chalice/config.json` (you'll need to inject COMPETITION_* yourself).
# WEBHOOK_URL=https://your-handler.example.com/webhook
